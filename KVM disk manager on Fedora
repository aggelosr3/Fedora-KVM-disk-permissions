#!/bin/bash
# ============================================================
# kvm-disk-manager.sh
# Disk Manager για KVM/QEMU - Fedora
# Δημιουργήθηκε: 2026-04-25
# ============================================================

# --- Χρώματα ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# --- Βοηθητικές συναρτήσεις ---
info()    { echo -e "${BLUE}[INFO]${NC} $1"; }
success() { echo -e "${GREEN}[✔]${NC} $1"; }
warn()    { echo -e "${YELLOW}[⚠]${NC} $1"; }
error()   { echo -e "${RED}[✘]${NC} $1"; }
step()    { echo -e "${CYAN}[→]${NC} $1"; }

ask_confirm() {
    # $1 = μήνυμα
    echo ""
    echo -e "${YELLOW}Τι θα γίνει:${NC} $1"
    echo -ne "${BOLD}Συνεχίζω; [y/N]: ${NC}"
    read -r answer
    [[ "$answer" =~ ^[Yy]$ ]]
}

# ============================================================
# CHECK 1: Τρέχει ως root;
# ============================================================
check_root() {
    step "Έλεγχος αν τρέχεις με sudo..."
    if [[ $EUID -ne 0 ]]; then
        error "Το script χρειάζεται sudo."
        echo -e "  Τρέξε: ${BOLD}sudo bash kvm-disk-manager.sh${NC}"
        exit 1
    fi
    success "Τρέχει με root δικαιώματα."
}

# ============================================================
# CHECK 2: Απαιτούμενα εργαλεία
# ============================================================
check_dependencies() {
    step "Έλεγχος απαιτούμενων εργαλείων (lsblk, ntfs-3g, setfacl, libvirtd)..."
    local missing=()

    for tool in lsblk ntfs-3g setfacl libvirtd; do
        if ! command -v "$tool" &>/dev/null; then
            missing+=("$tool")
        fi
    done

    if [[ ${#missing[@]} -gt 0 ]]; then
        warn "Λείπουν τα παρακάτω εργαλεία: ${missing[*]}"
        if ask_confirm "Θα εγκατασταθούν τα εργαλεία: ${missing[*]} με dnf install"; then
            dnf install -y ntfs-3g acl libvirt &>/dev/null
            success "Εγκαταστάθηκαν."
        else
            error "Δεν μπορώ να συνεχίσω χωρίς τα απαιτούμενα εργαλεία."
            exit 1
        fi
    else
        success "Όλα τα εργαλεία είναι διαθέσιμα."
    fi
}

# ============================================================
# CHECK 3: libvirtd τρέχει;
# ============================================================
check_libvirtd() {
    step "Έλεγχος αν το libvirtd τρέχει..."
    if ! systemctl is-active --quiet libvirtd; then
        warn "Το libvirtd δεν τρέχει."
        if ask_confirm "Θα ενεργοποιηθεί το libvirtd (systemctl enable --now libvirtd)"; then
            systemctl enable --now libvirtd
            success "libvirtd ενεργοποιήθηκε."
        else
            warn "Συνεχίζω χωρίς libvirtd..."
        fi
    else
        success "libvirtd τρέχει κανονικά."
    fi
}

# ============================================================
# CHECK 4: qemu user υπάρχει;
# ============================================================
check_qemu_user() {
    step "Έλεγχος αν ο qemu user υπάρχει στο σύστημα..."
    if ! id "qemu" &>/dev/null; then
        error "Ο qemu user δεν βρέθηκε. Βεβαιώσου ότι το KVM/QEMU είναι εγκατεστημένο."
        exit 1
    fi
    success "qemu user βρέθηκε (uid=$(id -u qemu))."
}

# ============================================================
# Έλεγχος αν partition πρέπει να παραλειφθεί
# ============================================================
should_skip() {
    local name="$1" fstype="$2" label="$3"

    # Check: whole disk (sda/sdb/sdd χωρίς partition number) → skip
    if [[ "$name" =~ ^(sd[a-z]|hd[a-z]|nvme[0-9]+n[0-9]+)$ ]]; then
        echo "Whole disk - όχι partition"
        return 0
    fi

    # Check: χωρίς filesystem → skip
    if [[ -z "$fstype" || "$fstype" == "-" ]]; then
        echo "Χωρίς filesystem (GPT/unformatted)"
        return 0
    fi

    # Check: EFI/vfat system partitions → skip
    if [[ "$fstype" == "vfat" ]]; then
        echo "EFI/vfat partition (boot) - μην αγγίζεις"
        return 0
    fi

    # Check: Recovery partition → skip (Windows recovery - μην χαλάσεις)
    if echo "$label" | grep -qi "recovery"; then
        echo "Windows Recovery partition - μην αγγίζεις"
        return 0
    fi

    # Check: swap → skip
    if [[ "$fstype" == "swap" ]]; then
        echo "Swap partition"
        return 0
    fi

    # Check: system nvme0 (Fedora OS disk) → skip
    if echo "$name" | grep -q "^nvme0"; then
        echo "Fedora system disk (nvme0) - μην αγγίζεις"
        return 0
    fi

    # Check: zram → skip
    if echo "$name" | grep -q "^zram"; then
        echo "zram (swap) - skip"
        return 0
    fi

    # Check: ήδη στο fstab → skip
    if grep -q "/dev/$name" "$FSTAB" 2>/dev/null; then
        echo "Ήδη στο fstab"
        return 0
    fi

    return 1
}

# ============================================================
# ΒΗΜΑ 1: Σάρωση δίσκων
# ============================================================
scan_disks() {
    step "Σαρώνω όλους τους δίσκους..."
    echo ""

    # Παίρνουμε ΟΛΑ τα partitions με separator | για ασφαλές parsing
    mapfile -t ALL_DEVICES < <(lsblk -rno NAME,FSTYPE,LABEL,SIZE,MOUNTPOINT -P |         sed "s/NAME=//g;s/FSTYPE=//g;s/LABEL=//g;s/SIZE=//g;s/MOUNTPOINT=//g" |         sed 's/" "/|/g;s/"//g')

    # Fallback αν το -P δεν δουλεύει
    if [[ ${#ALL_DEVICES[@]} -eq 0 ]]; then
        mapfile -t ALL_DEVICES < <(lsblk -rno NAME,FSTYPE,LABEL,SIZE,MOUNTPOINT)
    fi

    if [[ ${#ALL_DEVICES[@]} -eq 0 ]]; then
        error "Δεν βρέθηκαν δίσκοι."
        exit 1
    fi

    echo -e "${BOLD}╔════╦════════════╦════════╦═══════════════╦════════╦══════════════════════════════════╗${NC}"
    printf "${BOLD}║ %-2s ║ %-10s ║ %-6s ║ %-13s ║ %-6s ║ %-32s ║${NC}
" "#" "Device" "Type" "Label" "Size" "Status"
    echo -e "${BOLD}╠════╬════════════╬════════╬═══════════════╬════════╬══════════════════════════════════╣${NC}"

    DISK_LIST=()
    local i=1
    for entry in "${ALL_DEVICES[@]}"; do
        # Robust parsing: NAME FSTYPE LABEL SIZE MOUNTPOINT
        name=$(echo "$entry"     | awk "{print \$1}")
        fstype=$(echo "$entry"   | awk "{print \$2}")
        label=$(echo "$entry"    | awk "{print \$3}")
        size=$(echo "$entry"     | awk "{print \$4}")
        mountpoint=$(echo "$entry" | awk "{print \$5}")
        [[ -z "$label" || "$label" == "-" ]]      && label="-"
        [[ -z "$fstype" || "$fstype" == "-" ]]    && fstype="-"
        [[ -z "$mountpoint" || "$mountpoint" == "-" ]] && mountpoint="-"

        local skip_reason
        skip_reason=$(should_skip "$name" "$fstype" "$label")

        if [[ -n "$skip_reason" ]]; then
            # Εμφάνισε ως SKIP με αιτία
            printf "║ ${YELLOW}%-2s${NC} ║ %-10s ║ %-6s ║ %-13s ║ %-6s ║ ${YELLOW}SKIP: %-26s${NC} ║
"                 "-" "$name" "$fstype" "${label:0:13}" "$size" "${skip_reason:0:26}"
        else
            # Εμφάνισε ως διαθέσιμο
            if [[ "$fstype" == "ntfs" ]]; then
                COLOR="${YELLOW}"
            else
                COLOR="${GREEN}"
            fi
            printf "║ ${BOLD}${COLOR}%-2s${NC} ║ ${COLOR}%-10s${NC} ║ ${COLOR}%-6s${NC} ║ %-13s ║ %-6s ║ ${GREEN}%-32s${NC} ║
"                 "$i" "$name" "$fstype" "${label:0:13}" "$size" "Διαθέσιμος"
            DISK_LIST+=("$name|$fstype|$label|$size|$mountpoint")
            ((i++))
        fi
    done

    echo -e "${BOLD}╚════╩════════════╩════════╩═══════════════╩════════╩══════════════════════════════════╝${NC}"
    echo ""

    if [[ ${#DISK_LIST[@]} -eq 0 ]]; then
        success "Όλοι οι κατάλληλοι δίσκοι είναι ήδη ρυθμισμένοι."
        exit 0
    fi
}

# ============================================================
# ΒΗΜΑ 2: Επιλογή δίσκου (ή όλοι)
# ============================================================
SELECT_ALL=false

select_disk() {
    local max=${#DISK_LIST[@]}
    echo -ne "${BOLD}Επέλεξε δίσκο [1-$max] ή [a] για ΟΛΟΥΣ: ${NC}"
    read -r choice

    if [[ "$choice" =~ ^[Aa]$ ]]; then
        SELECT_ALL=true
        echo ""
        success "Επιλέχθηκαν ΟΛΟΙ οι διαθέσιμοι δίσκοι ($max σύνολο)."
        # Για το KVM setup χρησιμοποιούμε τον πρώτο ως SEL_*
        IFS='|' read -r SEL_NAME SEL_FSTYPE SEL_LABEL SEL_SIZE SEL_MOUNT <<< "${DISK_LIST[0]}"
        return
    fi

    # Check: έγκυρος αριθμός;
    if ! [[ "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > max )); then
        error "Μη έγκυρη επιλογή: '$choice'. Επέλεξε αριθμό 1-$max ή 'a' για όλους."
        exit 1
    fi

    SELECTED="${DISK_LIST[$((choice-1))]}"
    IFS='|' read -r SEL_NAME SEL_FSTYPE SEL_LABEL SEL_SIZE SEL_MOUNT <<< "$SELECTED"

    echo ""
    echo -e "${BOLD}Επιλέχθηκε:${NC}"
    echo -e "  Device : ${CYAN}/dev/$SEL_NAME${NC}"
    echo -e "  Τύπος  : ${CYAN}$SEL_FSTYPE${NC}"
    echo -e "  Label  : ${CYAN}$SEL_LABEL${NC}"
    echo -e "  Μέγεθος: ${CYAN}$SEL_SIZE${NC}"
    echo -e "  Mounted: ${CYAN}$SEL_MOUNT${NC}"
}

# ============================================================
# ΒΗΜΑ 3: Mount δίσκου
# ============================================================
mount_disk() {
    # Παίρνουμε το ΠΡΑΓΜΑΤΙΚΟ mountpoint από lsblk (χειρίζεται spaces σωστά)
    REAL_MOUNT=$(lsblk -rno MOUNTPOINT "/dev/$SEL_NAME" 2>/dev/null | grep -v '^$' | head -1)

    # Check: ήδη mounted;
    if [[ -n "$REAL_MOUNT" && -d "$REAL_MOUNT" ]]; then
        success "Ο δίσκος είναι ήδη mounted στο: $REAL_MOUNT"
        MOUNT_POINT="$REAL_MOUNT"
        return
    fi

    # Νέο mount point χωρίς spaces ή special characters
    CLEAN_LABEL=$(echo "$SEL_LABEL" | tr '[:upper:]' '[:lower:]' | tr ' ' '_' | tr -dc '[:alnum:]_-')
    # Check: αν label κενό ή μόνο παύλες → χρησιμοποίησε το device name
    CLEAN_LABEL=$(echo "$CLEAN_LABEL" | tr -d '-')
    [[ -z "$CLEAN_LABEL" ]] && CLEAN_LABEL=$(echo "$SEL_NAME" | tr -dc '[:alnum:]_')
    MOUNT_POINT="/mnt/kvm-${CLEAN_LABEL}"
    # Check: mount point δεν είναι κενό
    [[ -z "$CLEAN_LABEL" ]] && CLEAN_LABEL="disk-$(date +%s)" && MOUNT_POINT="/mnt/kvm-${CLEAN_LABEL}"


    # Ενημέρωση χρήστη
    echo ""
    if [[ "$SEL_FSTYPE" == "ntfs" ]]; then
        MSG="Ο δίσκος /dev/$SEL_NAME (NTFS) θα γίνει mount στο $MOUNT_POINT με ntfs-3g.\nΘα έχεις read/write πρόσβαση ως $(logname)."
    else
        MSG="Ο δίσκος /dev/$SEL_NAME ($SEL_FSTYPE) θα γίνει mount στο $MOUNT_POINT."
    fi

    if ask_confirm "$MSG"; then
        # Check: mount point υπάρχει;
        if [[ ! -d "$MOUNT_POINT" ]]; then
            mkdir -p "$MOUNT_POINT"
            success "Δημιουργήθηκε το $MOUNT_POINT"
        fi

        # Mount ανάλογα με τύπο
        if [[ "$SEL_FSTYPE" == "ntfs" ]]; then
            if mount -t ntfs-3g -o uid="$(id -u "$(logname)")",gid="$(id -g "$(logname)")",rw,remove_hiberfile \
                "/dev/$SEL_NAME" "$MOUNT_POINT"; then
                success "Mount επιτυχές στο $MOUNT_POINT"
            else
                echo ""
                echo -e "${RED}[✘]${NC} Mount απέτυχε για /dev/$SEL_NAME"
                echo ""
                echo -e "${YELLOW}╔══════════════════════════════════════════════════════╗${NC}"
                echo -e "${YELLOW}║  ⚠ Πιθανό πρόβλημα: Windows Fast Startup/Hibernate  ║${NC}"
                echo -e "${YELLOW}╠══════════════════════════════════════════════════════╣${NC}"
                echo -e "${YELLOW}║  Αν μπήκες πρόσφατα σε Windows:                     ║${NC}"
                echo -e "${YELLOW}║                                                      ║${NC}"
                echo -e "${YELLOW}║  1. Μπες Windows                                     ║${NC}"
                echo -e "${YELLOW}║  2. Control Panel → Power Options                    ║${NC}"
                echo -e "${YELLOW}║  3. Απενεργοποίησε: Turn on fast startup             ║${NC}"
                echo -e "${YELLOW}║  4. Κάνε FULL Shutdown (όχι Restart)                 ║${NC}"
                echo -e "${YELLOW}║  5. Επανέλαβε το mount                               ║${NC}"
                echo -e "${YELLOW}╚══════════════════════════════════════════════════════╝${NC}"
                echo ""
                MOUNT_POINT=""
                return 1
            fi
        else
            if mount "/dev/$SEL_NAME" "$MOUNT_POINT"; then
                success "Mount επιτυχές στο $MOUNT_POINT"
            else
                error "Mount απέτυχε για /dev/$SEL_NAME."
                MOUNT_POINT=""
                return 1
            fi
        fi
    else
        warn "Ακυρώθηκε. Παραλείπω αυτόν τον δίσκο."
        MOUNT_POINT=""
        return 1
    fi
}

# ============================================================
# ΒΗΜΑ 4: Δικαιώματα για KVM/QEMU
# ============================================================
set_kvm_permissions() {
    # Check: αν δεν έγινε mount → παραλείπω
    if [[ -z "$MOUNT_POINT" ]]; then
        warn "Παραλείπω permissions — δεν υπάρχει mounted δίσκος."
        return
    fi
    echo ""
    if ask_confirm "Θα δοθούν δικαιώματα read/write/execute στον qemu user για το $MOUNT_POINT.\nΑυτό χρειάζεται για να τρέχει το virt-manager χωρίς Permission Denied."; then

        # Check: setfacl διαθέσιμο;
        if ! command -v setfacl &>/dev/null; then
            error "Το setfacl δεν βρέθηκε."
            exit 1
        fi

        # Check: το path υπάρχει πραγματικά;
        if [[ ! -d "$MOUNT_POINT" ]]; then
            error "Το path '$MOUNT_POINT' δεν βρέθηκε. Βεβαιώσου ότι ο δίσκος είναι mounted."
            exit 1
        fi

        # Εκτέλεση setfacl με quoted path
        if setfacl -R -m u:qemu:rwx "$MOUNT_POINT"; then
            success "Δικαιώματα qemu:rwx δόθηκαν στο $MOUNT_POINT"
        else
            error "setfacl απέτυχε στο '$MOUNT_POINT'"
            exit 1
        fi

        # Δικαιώματα και στο parent directory
        PARENT=$(dirname "$MOUNT_POINT")
        if setfacl -m u:qemu:rx "$PARENT"; then
            success "Δικαιώματα qemu:rx δόθηκαν στο $PARENT"
        else
            warn "setfacl στο parent '$PARENT' απέτυχε (μη κρίσιμο)."
        fi
    else
        warn "Παραλείφθηκε το βήμα δικαιωμάτων."
    fi
}

# ============================================================
# ΒΗΜΑ 5: Ενημέρωση qemu.conf
# ============================================================
update_qemu_conf() {
    local conf="/etc/libvirt/qemu.conf"
    local current_user
    current_user=$(logname)

    echo ""

    # Check: αρχείο υπάρχει;
    if [[ ! -f "$conf" ]]; then
        error "Δεν βρέθηκε το $conf. Είναι εγκατεστημένο το libvirt;"
        exit 1
    fi

    if ask_confirm "Το $conf θα ενημερωθεί ώστε ο QEMU να τρέχει ως user='$current_user' και group='libvirt'.\nΑυτό λύνει το 'Permission Denied (uid:107)' error στο virt-manager."; then

        # Backup πρώτα
        cp "$conf" "${conf}.bak.$(date +%Y%m%d%H%M%S)"
        success "Backup δημιουργήθηκε: ${conf}.bak.*"

        # Check: γραμμές υπάρχουν;
        if grep -q '^#user' "$conf" || grep -q '^user' "$conf"; then
            sed -i "s/^#*user\s*=.*/user = \"$current_user\"/" "$conf"
        else
            echo "user = \"$current_user\"" >> "$conf"
        fi

        if grep -q '^#group' "$conf" || grep -q '^group' "$conf"; then
            sed -i 's/^#*group\s*=.*/group = "libvirt"/' "$conf"
        else
            echo 'group = "libvirt"' >> "$conf"
        fi

        success "qemu.conf ενημερώθηκε (user=$current_user, group=libvirt)"

        # Restart libvirtd
        if ask_confirm "Θα γίνει restart το libvirtd για να πάρει effect η αλλαγή."; then
            systemctl restart libvirtd
            # Check: restart πέτυχε;
            if systemctl is-active --quiet libvirtd; then
                success "libvirtd επανεκκινήθηκε επιτυχώς."
            else
                error "libvirtd δεν εκκινήθηκε σωστά. Τρέξε: journalctl -xe"
                exit 1
            fi
        fi
    else
        warn "Παραλείφθηκε η ενημέρωση qemu.conf."
    fi
}

# ============================================================
# BACKUP MANAGER
# ============================================================
BACKUP_DIR="/etc/fstab-backups"
FSTAB="/etc/fstab"
MAX_BACKUPS=10

fstab_backup() {
    # Δημιουργία backup directory αν δεν υπάρχει
    mkdir -p "$BACKUP_DIR"

    local backup_file="$BACKUP_DIR/fstab.bak.$(date +%Y%m%d-%H%M%S)"

    # Check: fstab υπάρχει;
    if [[ ! -f "$FSTAB" ]]; then
        error "Το $FSTAB δεν βρέθηκε!"
        exit 1
    fi

    cp "$FSTAB" "$backup_file"

    # Check: backup γράφτηκε;
    if [[ ! -f "$backup_file" ]]; then
        error "Backup απέτυχε: $backup_file"
        exit 1
    fi

    success "Backup δημιουργήθηκε: $backup_file"

    # Κράτα μόνο τα τελευταία MAX_BACKUPS
    local count
    count=$(ls -1 "$BACKUP_DIR"/fstab.bak.* 2>/dev/null | wc -l)
    if (( count > MAX_BACKUPS )); then
        ls -1t "$BACKUP_DIR"/fstab.bak.* | tail -n +$((MAX_BACKUPS+1)) | xargs rm -f
        success "Παλιά backups καθαρίστηκαν (κρατάω τα $MAX_BACKUPS πιο πρόσφατα)."
    fi
}

fstab_restore() {
    echo ""
    step "=== Restore fstab από backup ==="

    # Check: υπάρχουν backups;
    if [[ ! -d "$BACKUP_DIR" ]] || [[ -z "$(ls -A "$BACKUP_DIR" 2>/dev/null)" ]]; then
        error "Δεν βρέθηκαν backups στο $BACKUP_DIR"
        return
    fi

    echo ""
    echo -e "${BOLD}Διαθέσιμα backups:${NC}"
    local i=1
    local files=()
    while IFS= read -r f; do
        local ts
        ts=$(stat -c '%y' "$f" 2>/dev/null | cut -d'.' -f1)
        printf "  [%s] %s  (%s)
" "$i" "$(basename "$f")" "$ts"
        files+=("$f")
        ((i++))
    done < <(ls -1t "$BACKUP_DIR"/fstab.bak.* 2>/dev/null)

    echo ""
    echo -ne "${BOLD}Ποιο να κάνω restore; [1-${#files[@]}] ή [q] για έξοδο: ${NC}"
    read -r choice

    # Check: έγκυρη επιλογή;
    if [[ "$choice" == "q" ]]; then
        warn "Ακύρωση restore."
        return
    fi
    if ! [[ "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#files[@]} )); then
        error "Μη έγκυρη επιλογή."
        return
    fi

    local selected="${files[$((choice-1))]}"
    echo ""
    echo -e "${YELLOW}Τι θα γίνει:${NC}"
    echo -e "  Το τρέχον $FSTAB θα αντικατασταθεί"
    echo -e "  από το: ${CYAN}$(basename "$selected")${NC}"
    echo -e "  Θα τρέξει: systemctl daemon-reload"
    echo ""
    echo -ne "${BOLD}Συνεχίζω; [y/N]: ${NC}"
    read -r ans

    if [[ "$ans" =~ ^[Yy]$ ]]; then
        # Backup του τρέχοντος πριν το restore
        fstab_backup
        cp "$selected" "$FSTAB"
        # Check: αντιγράφηκε σωστά;
        if diff -q "$selected" "$FSTAB" &>/dev/null; then
            success "Restore ολοκληρώθηκε από: $(basename "$selected")"
            systemctl daemon-reload
            success "systemctl daemon-reload ολοκληρώθηκε."
        else
            error "Restore απέτυχε — τα αρχεία διαφέρουν."
        fi
    else
        warn "Restore ακυρώθηκε."
    fi
}

backup_menu() {
    echo ""
    echo -e "${BOLD}╔══════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}║         Backup Manager - /etc/fstab          ║${NC}"
    echo -e "${BOLD}╠══════════════════════════════════════════════╣${NC}"

    # Εμφάνισε υπάρχοντα backups
    if [[ -d "$BACKUP_DIR" ]] && ls "$BACKUP_DIR"/fstab.bak.* &>/dev/null; then
        echo -e "║ Υπάρχοντα backups:                           ║"
        while IFS= read -r f; do
            local ts
            ts=$(stat -c '%y' "$f" 2>/dev/null | cut -d'.' -f1)
            printf "║   %-42s ║
" "$(basename "$f") ($ts)"
        done < <(ls -1t "$BACKUP_DIR"/fstab.bak.* 2>/dev/null | head -5)
    else
        echo -e "║ Δεν υπάρχουν ακόμα backups.                  ║"
    fi

    echo -e "${BOLD}╠══════════════════════════════════════════════╣${NC}"
    echo -e "║  [b] Δημιούργησε backup τώρα                 ║"
    echo -e "║  [r] Κάνε restore από backup                 ║"
    echo -e "║  [c] Συνέχεια (χωρίς αλλαγή)                ║"
    echo -e "${BOLD}╚══════════════════════════════════════════════╝${NC}"
    echo ""
    echo -ne "${BOLD}Επιλογή [b/r/c]: ${NC}"
    read -r bm_choice

    case "$bm_choice" in
        b|B)
            fstab_backup
            ;;
        r|R)
            fstab_restore
            ;;
        c|C|"")
            info "Συνεχίζω..."
            ;;
        *)
            warn "Μη έγκυρη επιλογή. Συνεχίζω..."
            ;;
    esac
}

# ============================================================
# ΒΗΜΑ 6: Auto-mount ΟΛΩΝ των δίσκων στο fstab
# ============================================================
setup_fstab_all() {
    local current_user
    current_user=$(logname)
    local uid
    uid=$(id -u "$current_user")
    local gid
    gid=$(id -g "$current_user")

    echo ""
    step "Σαρώνω όλους τους δίσκους για auto-mount..."

    # Χρησιμοποιούμε το DISK_LIST από scan_disks (ήδη φιλτραρισμένο)
    # Αν SELECT_ALL=false, χρησιμοποιούμε μόνο τον επιλεγμένο δίσκο
    local source_list=()
    if [[ "$SELECT_ALL" == true ]]; then
        source_list=("${DISK_LIST[@]}")
    else
        source_list=("$SEL_NAME|$SEL_FSTYPE|$SEL_LABEL|$SEL_SIZE|$SEL_MOUNT")
    fi

    if [[ ${#source_list[@]} -eq 0 ]]; then
        warn "Δεν βρέθηκαν δίσκοι για auto-mount."
        return
    fi

    # Εμφάνισε λίστα
    echo ""
    echo -e "${BOLD}Δίσκοι που θα προστεθούν στο fstab:${NC}"
    echo ""
    local to_add=()
    for entry in "${source_list[@]}"; do
        IFS='|' read -r name fstype label size mountpoint <<< "$entry"
        [[ -z "$label" ]] && label="-"

        # Check: ήδη στο fstab (double-check);
        if grep -q "/dev/$name" "$FSTAB" 2>/dev/null; then
            printf "  ${YELLOW}[SKIP]${NC} /dev/%-10s %-6s %-15s %s (ήδη στο fstab)
" "$name" "$fstype" "$label" "$size"
            continue
        fi

        local clean_label
        clean_label=$(echo "$label" | tr '[:upper:]' '[:lower:]' | tr ' ' '_' | tr -dc '[:alnum:]_-')
        [[ -z "$clean_label" || "$clean_label" == "-" ]] && clean_label="$name"
        local mpoint="/mnt/auto-${clean_label}"

        printf "  ${GREEN}[ADD]${NC}  /dev/%-10s %-6s %-15s %s → %s
" "$name" "$fstype" "$label" "$size" "$mpoint"
        to_add+=("$name|$fstype|$label|$mpoint")
    done

    if [[ ${#to_add[@]} -eq 0 ]]; then
        success "Όλοι οι δίσκοι είναι ήδη στο fstab."
        return
    fi

    echo ""
    echo -e "${YELLOW}Τι θα γίνει:${NC}"
    echo -e "  - Backup του $FSTAB στο $BACKUP_DIR"
    echo -e "  - Δημιουργία directories /mnt/auto-*"
    echo -e "  - Προσθήκη ${#to_add[@]} δίσκων στο fstab με nofail"
    echo -e "  - systemctl daemon-reload"
    echo -e "  - Δοκιμαστικό mount για κάθε δίσκο"
    echo ""
    echo -ne "${BOLD}Συνεχίζω; [y/N]: ${NC}"
    read -r answer

    if ! [[ "$answer" =~ ^[Yy]$ ]]; then
        warn "Ακυρώθηκε."
        return
    fi

    # Backup ΠΡΙΝ οποιαδήποτε αλλαγή
    fstab_backup

    for entry in "${to_add[@]}"; do
        IFS='|' read -r name fstype label mpoint <<< "$entry"

        # Check: mount point directory;
        if [[ ! -d "$mpoint" ]]; then
            mkdir -p "$mpoint"
            success "Directory: $mpoint δημιουργήθηκε."
        fi

        # Δημιουργία fstab γραμμής
        local fstab_line
        if [[ "$fstype" == "ntfs" ]]; then
            fstab_line="/dev/$name  $mpoint  ntfs-3g  uid=$uid,gid=$gid,rw,nofail,x-systemd.automount  0  0"
        else
            fstab_line="/dev/$name  $mpoint  $fstype  defaults,nofail,x-systemd.automount  0  0"
        fi

        echo "$fstab_line" >> "$FSTAB"

        # Check: γράφτηκε σωστά;
        if grep -qF "$mpoint" "$FSTAB"; then
            success "/dev/$name → $mpoint ✔"
        else
            error "/dev/$name → εγγραφή στο fstab απέτυχε ✘"
        fi
    done

    # Reload systemd
    systemctl daemon-reload
    success "systemctl daemon-reload ολοκληρώθηκε."

    # Δοκιμαστικό mount για κάθε νέο δίσκο
    echo ""
    step "Δοκιμαστικό mount για κάθε δίσκο..."
    for entry in "${to_add[@]}"; do
        IFS='|' read -r name fstype label mpoint <<< "$entry"
        if mount "$mpoint" 2>/dev/null; then
            success "Mount: $mpoint → OK ✔"
        else
            warn "Mount: $mpoint → απέτυχε (ίσως χρειάζεται reboot ή ο δίσκος δεν είναι συνδεδεμένος)"
        fi
    done
}

# ============================================================
# ΒΗΜΑ 7: Επαλήθευση λειτουργίας
# ============================================================
verify_all() {
    echo ""
    step "Εκτελώ τελικό έλεγχο λειτουργίας..."
    echo ""

    local all_ok=true

    # Check 1: MOUNT_POINT ορισμένο και mounted;
    if [[ -z "$MOUNT_POINT" ]]; then
        warn "Κανένας επιλεγμένος δίσκος δεν έγινε mount — παραλείπω έλεγχο mount."
    elif mountpoint -q "$MOUNT_POINT" 2>/dev/null; then
        success "Mount: $MOUNT_POINT → mounted ✔"
    elif [[ -d "$MOUNT_POINT" ]]; then
        success "Mount: $MOUNT_POINT → directory υπάρχει ✔"
    else
        error "Mount: $MOUNT_POINT → ΔΕΝ βρέθηκε ✘"
        all_ok=false
    fi

    # Check 2: qemu ACL
    if getfacl "$MOUNT_POINT" 2>/dev/null | grep -q "user:qemu:rwx"; then
        success "qemu ACL: rwx ✔"
    else
        warn "qemu ACL: δεν επαληθεύτηκε (μπορεί να είναι OK αν χρησιμοποιείς qemu.conf)"
    fi

    # Check 3: libvirtd τρέχει
    if systemctl is-active --quiet libvirtd; then
        success "libvirtd: τρέχει ✔"
    else
        error "libvirtd: ΔΕΝ τρέχει ✘"
        all_ok=false
    fi

    # Check 4: qemu.conf user
    local conf="/etc/libvirt/qemu.conf"
    if grep -q "^user" "$conf" 2>/dev/null; then
        local conf_user
        conf_user=$(grep "^user" "$conf" | head -1)
        success "qemu.conf: $conf_user ✔"
    else
        warn "qemu.conf: user γραμμή δεν βρέθηκε"
    fi

    # Check 5: Δοκιμαστική εγγραφή (μόνο αν MOUNT_POINT ορισμένο)
    if [[ -n "$MOUNT_POINT" && -d "$MOUNT_POINT" ]]; then
        local testfile="$MOUNT_POINT/.kvm_write_test"
        if touch "$testfile" 2>/dev/null; then
            rm -f "$testfile"
            success "Δοκιμαστική εγγραφή: $MOUNT_POINT → OK ✔"
        else
            error "Δοκιμαστική εγγραφή: $MOUNT_POINT → ΑΠΟΤΥΧΙΑ ✘"
            all_ok=false
        fi
    else
        warn "Δοκιμαστική εγγραφή: παραλείπεται (δεν υπάρχει mounted δίσκος)."
    fi

    echo ""
    if [[ "$all_ok" == true ]]; then
        echo -e "${GREEN}${BOLD}✅ Όλοι οι έλεγχοι πέρασαν! Το virt-manager είναι έτοιμο.${NC}"
    else
        echo -e "${RED}${BOLD}⚠ Κάποιοι έλεγχοι απέτυχαν. Δες τα errors παραπάνω.${NC}"
    fi
}

# ============================================================
# ΒΗΜΑ 9: Symlink Manager (Linux φάκελοι → άλλος δίσκος)
# ============================================================
symlink_manager() {
    echo ""
    echo -e "${BOLD}╔══════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}║       Symlink Manager - Φάκελοι Linux        ║${NC}"
    echo -e "${BOLD}╠══════════════════════════════════════════════╣${NC}"
    echo -e "║  Μετακίνησε φακέλους Linux σε άλλο δίσκο    ║${NC}"
    echo -e "${BOLD}╚══════════════════════════════════════════════╝${NC}"
    echo ""

    local current_user
    current_user=$(logname)
    local home_dir
    home_dir=$(eval echo "~$current_user")

    # Check: kdialog (KDE) ή zenity (GNOME) διαθέσιμο;
    if ! command -v kdialog &>/dev/null && ! command -v zenity &>/dev/null; then
        warn "Δεν βρέθηκε kdialog ή zenity."
        echo -ne "${BOLD}Να εγκαταστήσω kdialog (KDE); [y/N]: ${NC}"
        read -r inst
        if [[ "$inst" =~ ^[Yy]$ ]]; then
            dnf install -y kdialog &>/dev/null
            if ! command -v kdialog &>/dev/null; then
                error "Εγκατάσταση kdialog απέτυχε. Παραλείπω symlink manager."
                return
            fi
            success "kdialog εγκαταστάθηκε."
        else
            warn "Παραλείπω symlink manager."
            return
        fi
    fi
    # Εμφάνισε ποιο tool θα χρησιμοποιηθεί
    if command -v kdialog &>/dev/null; then
        info "Χρησιμοποιώ: kdialog (Dolphin style)"
    else
        info "Χρησιμοποιώ: zenity (GNOME style)"
    fi

    echo -ne "${BOLD}Θέλεις να ρυθμίσεις symlinks φακέλων; [y/N]: ${NC}"
    read -r do_symlink
    [[ ! "$do_symlink" =~ ^[Yy]$ ]] && return

    # Λίστα φακέλων
    local folders=("Documents" "Music" "Pictures" "Videos" "Downloads")

    for folder in "${folders[@]}"; do
        local src="$home_dir/$folder"
        echo ""
        echo -e "${BOLD}--- $folder ---${NC}"

        # Check: είναι ήδη symlink;
        if [[ -L "$src" ]]; then
            local current_target
            current_target=$(readlink -f "$src")
            warn "$folder είναι ήδη symlink → $current_target"
            echo -ne "  Θέλεις να το αλλάξεις; [y/N]: "
            read -r change_it
            [[ ! "$change_it" =~ ^[Yy]$ ]] && continue
        fi

        echo -e "  Άνοιγμα file picker για τον προορισμό του ${CYAN}$folder${NC}..."
        echo -e "  ${YELLOW}(Πλοηγήσου στον δίσκο σου και επέλεξε φάκελο)${NC}"

        # Zenity file picker - ανοίγει στο /mnt αν υπάρχει
        local start_dir="/mnt"
        [[ ! -d "$start_dir" ]] && start_dir="/"

        local dest
        local uid_user
        uid_user=$(id -u "$current_user")
        local dbus_addr="unix:path=/run/user/${uid_user}/bus"

        # Προσπάθησε kdialog πρώτα (KDE/Dolphin), μετά zenity (GNOME)
        if command -v kdialog &>/dev/null; then
            dest=$(sudo -u "$current_user"                 DISPLAY=:0                 DBUS_SESSION_BUS_ADDRESS="$dbus_addr"                 kdialog                 --getexistingdirectory "$start_dir"                 --title "Επέλεξε προορισμό για: $folder"                 2>/dev/null)
        elif command -v zenity &>/dev/null; then
            dest=$(sudo -u "$current_user"                 DISPLAY=:0                 DBUS_SESSION_BUS_ADDRESS="$dbus_addr"                 zenity --file-selection                 --directory                 --title="Επέλεξε προορισμό για: $folder"                 --filename="$start_dir/"                 2>/dev/null)
        else
            error "Δεν βρέθηκε kdialog ή zenity. Εγκατάστησε: dnf install kdialog"
            warn "Παραλείπω $folder."
            continue
        fi

        # Check: επιλέχθηκε path;
        if [[ -z "$dest" ]]; then
            warn "Δεν επιλέχθηκε φάκελος για $folder. Παραλείπω."
            continue
        fi

        # Check: ο προορισμός υπάρχει ή να δημιουργηθεί;
        local final_dest="$dest/$folder"
        echo ""
        echo -e "${YELLOW}Τι θα γίνει για $folder:${NC}"
        echo -e "  1. Δημιουργία: ${CYAN}$final_dest${NC}"
        if [[ -d "$src" && ! -L "$src" ]]; then
            echo -e "  2. Αντιγραφή περιεχομένου: ${CYAN}$src${NC} → ${CYAN}$final_dest${NC}"
            echo -e "  3. Διαγραφή αρχικού: ${CYAN}$src${NC}"
        fi
        echo -e "  4. Δημιουργία symlink: ${CYAN}$src${NC} → ${CYAN}$final_dest${NC}"
        echo ""
        echo -ne "${BOLD}Συνεχίζω; [y/N]: ${NC}"
        read -r confirm

        [[ ! "$confirm" =~ ^[Yy]$ ]] && warn "Παραλείπω $folder." && continue

        # Δημιουργία προορισμού
        mkdir -p "$final_dest"
        chown "$current_user:$current_user" "$final_dest"

        # Check: δημιουργήθηκε;
        if [[ ! -d "$final_dest" ]]; then
            error "Δεν μπόρεσα να δημιουργήσω: $final_dest"
            continue
        fi

        # Αντιγραφή περιεχομένου αν υπάρχει αρχικός φάκελος (όχι symlink)
        if [[ -d "$src" && ! -L "$src" ]]; then
            if cp -r "$src/." "$final_dest/" 2>/dev/null; then
                success "Αντιγραφή περιεχομένου: OK ✔"
            else
                warn "Αντιγραφή απέτυχε — ο προορισμός μπορεί να είναι κενός."
            fi
            rm -rf "$src"
        elif [[ -L "$src" ]]; then
            rm -f "$src"
        fi

        # Δημιουργία symlink
        sudo -u "$current_user" ln -s "$final_dest" "$src"

        # Check: symlink δημιουργήθηκε σωστά;
        if [[ -L "$src" ]] && [[ "$(readlink -f "$src")" == "$final_dest" ]]; then
            success "$folder → $final_dest ✔"
        else
            error "Symlink απέτυχε για $folder ✘"
        fi
    done
}

